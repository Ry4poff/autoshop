ANTISTOCK_BASE_URL=https://business-api.antistock.io
ANTISTOCK_API_TOKEN=TON_SECRET_TOKEN_ANTISTOCK
ANTISTOCK_SHOP_ID=TON_SHOP_ID_UUID

# Endpoint confirmé par la doc publique: /v1/dash/shops/{shopId}/warehouses/{warehouseId}/stock/raw
# Pour retirer 1 stock, Antistock expose delete-stock mais le body exact dépend de leur OpenAPI.
# Essaie d'abord avec id_list. Si ça ne marche pas, adapte avec custom template.
ANTISTOCK_DELETE_STRATEGY=id_list
# Options: id_list | stock_ids | raw_lines | custom
ANTISTOCK_DELETE_CUSTOM_TEMPLATE={"ids":["{{id}}"]}
